function ChatBubble({ kind = "assistant", title, eyebrow, icon: Icon, children, accent = "" }) {
  return html`<article className=${`chat-row ${kind === "user" ? "is-user" : ""}`}>
    <div className=${`chat-bubble ${kind === "user" ? "is-user" : ""} ${accent}`}>
